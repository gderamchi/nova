# Nova - Environment Variables
# Copy this file to .env.local and fill in your keys

# AI — Claude API for intent parsing
ANTHROPIC_API_KEY=

# Telegram — Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Wallet — Server private key (testnet only!)
NOVA_PRIVATE_KEY=

# Pimlico — ERC-4337 Account Abstraction
NEXT_PUBLIC_PIMLICO_API_KEY=

# RPC — Blockchain nodes
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://base-sepolia-rpc.publicnode.com
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://arbitrum-sepolia-rpc.publicnode.com

# Uniswap — API key from developers.uniswap.org
NEXT_PUBLIC_UNISWAP_API_KEY=

# Hedera — Testnet credentials
NEXT_PUBLIC_HEDERA_ACCOUNT_ID=
NEXT_PUBLIC_HEDERA_PRIVATE_KEY=

# Arc/Circle — Nanopayments
NEXT_PUBLIC_ARC_API_KEY=

# 0G — Decentralized storage
NEXT_PUBLIC_0G_API_KEY=

# Alchemy (optional)
NEXT_PUBLIC_ALCHEMY_API_KEY=
